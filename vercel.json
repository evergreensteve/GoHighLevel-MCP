{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { 
      "src": "/sse", 
      "dest": "dist/index.js" 
    },
    { 
      "src": "/messages", 
      "dest": "dist/index.js" 
    },
    { 
      "src": "/(.*)", 
      "dest": "dist/index.js" 
    }
  ]
}
